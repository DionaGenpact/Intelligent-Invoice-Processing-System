{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Context",
  "description": "Runtime context shared across pipeline agents",
  "type": "object",
  "required": [
    "bundle_path",
    "manifest",
    "validation_result",
    "extraction_result",
    "policy_result",
    "decision_result",
    "evidence_index",
    "risk_flags",
    "ignored_files"
  ],
  "properties": {
    "bundle_path": {
      "type": "string",
      "minLength": 1
    },
    "manifest": {
      "$ref": "manifest.schema.json"
    },

    "validation_result": {
      "oneOf": [
        { "type": "object", "maxProperties": 0 },
        { "$ref": "validation.schema.json" }
      ]
    },

    "extraction_result": {
      "type": "object"
    },

    "policy_result": {
      "type": "object"
    },

    "decision_result": {
      "oneOf": [
        { "type": "object", "maxProperties": 0 },
        { "$ref": "decision.schema.json" }
      ]
    },

    "evidence_index": {
      "type": "object"
    },

    "risk_flags": {
      "type": "array",
      "items": { "type": "string" }
    },

    "ignored_files": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}