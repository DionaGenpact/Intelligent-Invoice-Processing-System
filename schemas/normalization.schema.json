{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NormalizationResult",
  "description": "Result of invoice total normalization and reconciliation",
  "type": "object",
  "required": [
    "normalized",
    "calculated_total",
    "declared_total",
    "errors"
  ],
  "properties": {
    "normalized": {
      "type": "boolean"
    },
    "calculated_total": {
      "type": "number"
    },
    "declared_total": {
      "type": "number"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}