{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PostingPayload",
  "type": "object",
  "required": [
    "document_type",
    "invoice_number",
    "invoice_date",
    "vendor_id",
    "currency",
    "gross_amount",
    "posting_status",
    "line_items"
  ],
  "properties": {
    "document_type": {"type": "string"},
    "invoice_number": {"type": ["string", "null"]},
    "invoice_date": {"type": ["string", "null"]},
    "vendor_id": {"type": ["string", "null"]},
    "vendor_name": {"type": ["string", "null"]},
    "currency": {"type": ["string", "null"]},
    "gross_amount": {"type": ["number", "null"]},
    "po_number": {"type": ["string", "null"]},
    "match_mode": {"type": ["string", "null"]},
    "route_to": {"type": ["string", "null"]},
    "posting_status": {"type": "string"},
    "approval_decision": {"type": ["string", "null"]},
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["line_number", "description", "quantity", "unit_price", "line_total"],
        "properties": {
          "line_number": {"type": ["integer", "null"]},
          "description": {"type": ["string", "null"]},
          "quantity": {"type": ["number", "null"]},
          "unit_price": {"type": ["number", "null"]},
          "line_total": {"type": ["number", "null"]}
        },
        "additionalProperties": false
      }
    },
    "evidence_refs": {"type": "object"},
    "vendor_master_match": {"type": "object"}
  },
  "additionalProperties": false
}
