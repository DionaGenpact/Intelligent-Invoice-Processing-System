{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ValidationResult",
  "description": "Result of bundle validation checks",
  "type": "object",
  "required": ["is_valid", "errors", "warnings"],
  "properties": {
    "is_valid": { "type": "boolean" },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 0
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 0
    }
  },
  "additionalProperties": false
}